<!-- Status-bar small icon: white silhouette on transparent.
     Android tints this with the system/notification accent color. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Play triangle silhouette with curved sides (no straight edges).
         Anchors TL (4,6), BL (4,18), tip (15,12); corner r~2. -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M4,8
                          Q3,12 4,16
                          Q4,18 5.76,17.04
                          Q9.98,15.88 13.24,12.96
                          Q15,12 13.24,11.04
                          Q9.98,8.12 5.76,6.96
                          Q4,6 4,8 Z" />

    <!-- Two tight sound-wave arcs centered at (14,12). -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M15.49,10.08 A2.5,2.5 0 0,1 15.49,13.92" />

    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M17.27,8.38 A5,5 0 0,1 17.27,15.62" />
</vector>
